{
  "$merge": {
    "source": {
      "$import": "../oxc/ArticleDefinition.json"
    },
    "with": {
      "$id": "https://openxcom.org/schemas/oxce/ArticleDefinition.json",
      "properties": {
        "disabledBy": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "hiddenCommendation": {
          "type": "boolean"
        },
        "align_bottom": {
          "type": "boolean"
        },
        "rect_armor": {
          "$ref": "#/definitions/ArticleDefinitionRect"
        },
        "unit_mode": {
          "type": "integer"
        },
        "psi_skill_mode": {
          "type": "integer"
        },
        "type_id": {
          "type": "integer",
          "minimum": 0,
          "maximum": 19
        },
        "pages": {
          "items": {
            "$ref": "#/definitions/ArticlePage"
          },
          "type": "array"
        }
      },
      "definitions": {
        "ArticlePage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "title": {
              "type": "string"
            },
            "text": {
              "type": "string"
            },
            "ammoSlot": {
              "type": "integer"
            }
          }
        }
      }
    }
  }
}