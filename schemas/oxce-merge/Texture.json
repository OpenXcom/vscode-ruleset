{
  "$merge": {
    "source": {
      "$import": "../oxc/Texture.json"
    },
    "with": {
      "$id": "https://openxcom.org/schemas/oxce/Texture.json",
      "properties": {
        "isOcean": {
          "type": "boolean"
        },
        "baseGridSprite": {
          "$ref": "ModOffset.json"
        },
        "fakeUnderwater": {
          "type": "boolean"
        },
        "startingCondition": {
          "type": "string"
        },
        "baseTerrain": {
          "items": {
            "$ref": "Texture.json#/definitions/TerrainCriteria"
          },
          "type": "array"
        }
      }
    }
  }
}